{
    "name": "nathanpixodeo/mysql-tuner",
    "description": "MySQL / MariaDB performance analyzer and tuner – collects metrics and gives tuning recommendations",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.1",
        "ext-pdo": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^2.2"
    },
    "autoload": {
        "psr-4": {
            "MySQLTuner\\": "src/"
        }
    },
    "bin": [
        "bin/mysql-tuner"
    ],
    "scripts": {
        "test": "phpunit"
    }
}
